# Safe EchoSupport demo env template for Google Cloud Compute Engine.
# Copy values into .env on the VM and replace every placeholder before starting.
# Do not commit the filled .env file.

POSTGRES_DB=echosupport
POSTGRES_USER=echosupport
POSTGRES_PASSWORD=replace-with-a-strong-database-password

JWT_SECRET=replace-with-at-least-32-random-characters
MASTER_ENCRYPTION_KEY=replace-with-exactly-64-hex-characters
CRON_SECRET=replace-with-at-least-32-random-characters

ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=replace-with-a-long-unique-admin-password

# First launch can use http://EXTERNAL_IP. Change to https://your-domain after TLS.
PUBLIC_BASE_URL=http://EXTERNAL_IP
ADMIN_CORS_ORIGINS=http://EXTERNAL_IP
HTTP_PORT=80

# Use a separate OpenRouter key for the demo and set a small spend limit in OpenRouter.
OPENROUTER_API_KEY=
OPENROUTER_EMBEDDING_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
DEEPGRAM_API_KEY=

# Opt-in marketing demo copy. Leave false for ordinary production installs.
ECHOSUPPORT_DEMO_MARKETING_SEED=true

QDRANT_API_KEY=
MAX_DOCUMENT_SIZE_MB=50