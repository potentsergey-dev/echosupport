{
  "name": "echosupport",
  "version": "1.0.4",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.1.2"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:widget": "pnpm --filter @echosupport/widget build",
    "copy:widget": "node -e \"const fs=require('fs');const src='apps/widget/dist';const dst='apps/backend/public';fs.mkdirSync(dst,{recursive:true});fs.readdirSync(src).forEach(f=>fs.copyFileSync(src+'/'+f,dst+'/'+f));console.log('Widget files copied to backend/public')\"",
    "deploy:widget": "pnpm build:widget && pnpm copy:widget",
    "build:prod": "pnpm -r build && pnpm copy:widget",
    "check:release": "node scripts/check-release-consistency.mjs",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @echosupport/backend test",
    "test:coverage": "pnpm --filter @echosupport/backend test:coverage",
    "smoke:install": "node scripts/smoke-install-readiness.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "@rolldown/binding-win32-x64-msvc"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
