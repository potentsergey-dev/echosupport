# Copy this file to .env before starting Docker Compose.
# Do not start production with any replace-with-* values left in place.
POSTGRES_DB=echosupport
POSTGRES_USER=echosupport
POSTGRES_PASSWORD=replace-with-a-strong-database-password

# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-at-least-32-random-characters
# Generate with: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=replace-with-exactly-64-hex-characters
# Generate with: openssl rand -base64 48
CRON_SECRET=replace-with-at-least-32-random-characters

# Initial owner account. Use at least 12 characters for the password.
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=replace-with-a-long-unique-admin-password

# Optional restricted operator account. It can work with Inbox, appointments, and CSAT,
# but cannot change agents, API keys, knowledge, specialists, services, or schedules.
# Set both values or leave both empty. Use at least 12 characters for the password.
INITIAL_OPERATOR_EMAIL=
INITIAL_OPERATOR_PASSWORD=

# For Internet exposure, use your HTTPS origin, for example https://support.example.com.
PUBLIC_BASE_URL=http://localhost:8080
# Comma-separated browser origins allowed to use admin/operator/auth routes.
# Use origins only, no paths. Do not use *.
ADMIN_CORS_ORIGINS=http://localhost:8080
HTTP_PORT=8080

# Use pro for the full product or lite for a simpler knowledge-base assistant admin UI.
APP_EDITION=pro

# OpenRouter by default. You can also point OPENROUTER_BASE_URL to an OpenAI-compatible endpoint such as Ollama or vLLM.
# For local Ollama, use OPENROUTER_BASE_URL=http://host.docker.internal:11434/v1 on Docker Desktop,
# or http://127.0.0.1:11434/v1 when backend and Ollama run on the same host without Docker isolation.
# Some local endpoints do not require a real key; use a non-empty placeholder such as ollama.
OPENROUTER_API_KEY=
OPENROUTER_EMBEDDING_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
DEEPGRAM_API_KEY=

# Optional: only for public marketing demos. Keeps the normal production seed neutral.
ECHOSUPPORT_DEMO_MARKETING_SEED=false

QDRANT_API_KEY=
MAX_DOCUMENT_SIZE_MB=50
