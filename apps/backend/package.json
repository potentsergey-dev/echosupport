{
  "name": "@echosupport/backend",
  "version": "1.0.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:integration:check-db": "node scripts/assert-test-database.mjs",
    "test:integration": "vitest run --config vitest.integration.config.mts",
    "test:integration:ws": "vitest run --config vitest.integration.config.mts src/__tests__/websocket-security.integration.test.ts",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.7.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "4.1.6",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "vitest": "^4.1.6",
    "ws": "^8.21.0"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@langchain/textsplitters": "^1.0.1",
    "@mozilla/readability": "^0.6.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "^7.8.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "bcryptjs": "^3.0.0",
    "dotenv": "^16.0.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0",
    "jsdom": "^29.1.1",
    "mammoth": "^1.12.0",
    "openai": "^6.37.0",
    "pdf-parse": "^2.4.5",
    "pino-pretty": "^13.0.0",
    "zod": "^3.22.0"
  }
}
