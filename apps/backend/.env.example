# ─────────────────────────────────────────────
# Local development environment
# Copy from .env.example and fill in real values
# ─────────────────────────────────────────────

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Replace with your Neon / local PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/echosupport?sslmode=disable"

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars_long

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_ENCRYPTION_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

ADMIN_CORS_ORIGINS=http://localhost:5173
UPLOADS_DIR=./uploads
APP_URL=http://localhost:3000

# ── Phase 3: Knowledge Indexing ────────────────────────────────
# OpenAI key used as a global fallback for embeddings (agents can override with their own key)
OPENAI_API_KEY=sk-...

# Qdrant vector database
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=  # required only for Qdrant Cloud

# Max file size for document uploads (MB, default: 50)
MAX_DOCUMENT_SIZE_MB=50

# ── Phase 4: Chat Engine (OpenRouter) ──────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Phase 5: Speech-to-Text (Deepgram) ─────────────────────────
DEEPGRAM_API_KEY=...

# ── Production deployment ────────────────────────────────────────
# Public base URL — used in embed snippet generation and CORS
# PUBLIC_BASE_URL=https://support.example.by

# Secret for the external cron trigger endpoint (POST /api/v1/internal/cron/cleanup)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRON_SECRET=change_me_to_a_long_random_string
