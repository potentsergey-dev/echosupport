{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "noEmit": true
  },
  "include": ["src/**/*", "vite.config.ts", "vite.embed.config.ts"],
  "exclude": ["node_modules", "dist"]
}
